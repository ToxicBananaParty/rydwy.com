{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "anchor": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "order": {
      "type": "number"
    },
    "tools": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "images": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "src": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        },
        "required": [
          "src",
          "alt"
        ]
      }
    },
    "video": {
      "type": "object",
      "properties": {
        "src": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        }
      },
      "required": [
        "src"
      ]
    },
    "link": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "href": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "label",
        "href"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "anchor",
    "order",
    "tools"
  ]
}